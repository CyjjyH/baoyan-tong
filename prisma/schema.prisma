// Prisma Schema — 保研信息聚合平台

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "sqlite"
}

// ==================== 用户 & 认证 ====================

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  emailVerified DateTime?
  image         String?
  hashedPassword String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  accounts      Account[]
  sessions      Session[]
  favorites        Favorite[]
  subscriptions    Subscription[]
  submissions      Submission[]
  submittedNotices Notice[]       @relation("SubmittedNotices")

  // NextAuth required fields
  authenticators Authenticator[]
}

model Account {
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([provider, providerAccountId])
}

model Session {
  sessionToken String   @id
  userId       String
  expires      DateTime
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@id([identifier, token])
}

model Authenticator {
  credentialID         String  @id
  userId               String
  providerAccountId    String
  credentialPublicKey  String
  counter              Int
  credentialDeviceType String
  credentialBackedUp   Boolean
  transports           String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, credentialID])
}

// ==================== 通知 ====================

model Notice {
  id                   String   @id @default(cuid())
  title                String
  schoolName           String
  college              String
  major                String
  type                 String   // SUMMER_CAMP | PRE_ADMISSION
  schoolLevel          String   // 985 | 211 | DOUBLE_FIRST_CLASS | OTHER
  province             String
  city                 String
  applicationStartDate DateTime
  applicationEndDate   DateTime
  activityStartDate    DateTime?
  activityEndDate      DateTime?
  applicationLink      String?
  originalLink         String?
  requirements         String?
  materials            String?

  // 管理字段
  source       String   @default("ADMIN") // ADMIN | AI | USER_SUBMISSION
  status       String   @default("PUBLISHED") // PENDING | PUBLISHED | REJECTED
  submitterId  String?
  submitter    User?    @relation("SubmittedNotices", fields: [submitterId], references: [id])
  reviewNote   String?  // 审核备注
  aiConfidence Float?   // AI 提取置信度

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  favorites Favorite[]
}

// ==================== 收藏 ====================

model Favorite {
  id        String   @id @default(cuid())
  userId    String
  noticeId  String
  createdAt DateTime @default(now())

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  notice Notice @relation(fields: [noticeId], references: [id], onDelete: Cascade)

  @@unique([userId, noticeId])
}

// ==================== 订阅提醒 ====================

model Subscription {
  id          String   @id @default(cuid())
  userId      String
  name        String?  // 用户自定义名称，如"计算机985夏令营"
  keyword     String?  // 关键词
  major       String?  // 专业
  schoolLevels String? // JSON 数组，如 '["985","211"]'
  provinces   String?  // JSON 数组
  types       String?  // JSON 数组，如 '["SUMMER_CAMP"]'
  enabled     Boolean  @default(true)
  lastNotifiedAt DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// ==================== 用户投稿 ====================

model Submission {
  id                   String   @id @default(cuid())
  title                String
  schoolName           String
  college              String
  major                String
  type                 String
  schoolLevel          String
  province             String
  city                 String
  applicationStartDate DateTime
  applicationEndDate   DateTime
  activityStartDate    DateTime?
  activityEndDate      DateTime?
  applicationLink      String?
  originalLink         String?
  requirements         String?
  materials            String?

  status      String   @default("PENDING") // PENDING | APPROVED | REJECTED
  reviewNote  String?
  submitterId String
  submitter   User     @relation(fields: [submitterId], references: [id])
  reviewedBy  String?  // 审核人
  reviewedAt  DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ==================== AI 搜索日志 ====================

model AiSearchLog {
  id            String   @id @default(cuid())
  searchQuery   String
  resultsCount  Int
  newNotices    Int      @default(0)
  duplicates    Int      @default(0)
  errors        String?  // JSON 错误详情
  startedAt     DateTime @default(now())
  completedAt   DateTime?
  status        String   @default("RUNNING") // RUNNING | COMPLETED | FAILED
}
